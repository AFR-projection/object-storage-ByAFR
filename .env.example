# ═══════════════════════════════════════════════════════════
# Storage ByAFR — Environment Variables
# Copy: cp .env.example .env
# VPS : isi semua bagian "WAJIB VPS" sebelum deploy
# ═══════════════════════════════════════════════════════════

# ── WAJIB VPS ─────────────────────────────────────────────
# Database (Neon PostgreSQL — https://neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/storage?sslmode=require

# Cloudflare R2 (https://dash.cloudflare.com → R2)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=storage-by-afr
# Public bucket URL, contoh: https://pub-xxxx.r2.dev
R2_PUBLIC_URL=

# URL publik website (WAJIB sama dengan domain/IP yang diakses user)
# Contoh VPS tanpa domain: http://123.45.67.89
# Contoh dengan domain:     https://storage.domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin pertama — dipakai saat bootstrap
MASTER_USERNAME=ByAFR
MASTER_PASSWORD=change-this-strong-password

# Session — min 64 karakter random (vps-deploy.sh bisa generate otomatis)
SESSION_SECRET=change-this-to-a-random-64-character-string-minimum-for-production

# ── REDIS ─────────────────────────────────────────────────
# Local dev: REDIS_DISABLED=true OK
# VPS Docker: otomatis pakai redis container (jangan set REDIS_DISABLED=true)
REDIS_URL=redis://localhost:6379
REDIS_DISABLED=true

# ── OPSIONAL ──────────────────────────────────────────────
MAX_FILE_SIZE_BYTES=5368709120
UPLOAD_URL_EXPIRY_SECONDS=900
DOWNLOAD_URL_EXPIRY_SECONDS=60
PREVIEW_URL_EXPIRY_SECONDS=3600
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_IP_MAX=30
SESSION_INACTIVITY_MS=1800000
# SESSION_IP_BIND=true
