# ═══════════════════════════════════════════════════════════
# Storage ByAFR — Environment Variables
# Local : cp .env.example .env
# VPS   : cp .env.example .env → nano .env → ./install.sh
# ═══════════════════════════════════════════════════════════

# ── WAJIB ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=strogebyafr
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

NEXT_PUBLIC_APP_URL=https://storage.example.com

MASTER_USERNAME=ByAFR
MASTER_PASSWORD=change-this-strong-password-min-10-chars

SESSION_SECRET=change-this-to-a-random-64-character-string-minimum-for-production

# ── WAJIB VPS (production) ──────────────────────────────────
NODE_ENV=production
DEPLOY_DOMAIN=storage.example.com
CERTBOT_EMAIL=admin@example.com
COOKIE_SECURE=true
HSTS_ENABLED=true
REDIS_URL=redis://redis:6379
REDIS_DISABLED=false

# ── Email (Gmail SMTP sender) ───────────────────────────────
# Gmail senders are configured from the admin panel (Admin → Email), not env.
# Each sender's App Password is encrypted at rest with a key derived from
# SESSION_SECRET, so keep SESSION_SECRET stable across deploys or saved senders
# will need to be re-entered. No email-specific env vars are required.

# ── MCP (Cursor / Claude Desktop) ───────────────────────────
# STORAGE_API_URL=https://storage.dataku.id
# STORAGE_API_KEY=sk_or_skm_your_key
MAX_FILE_SIZE_BYTES=5368709120
UPLOAD_URL_EXPIRY_SECONDS=900
DOWNLOAD_URL_EXPIRY_SECONDS=60
PREVIEW_URL_EXPIRY_SECONDS=3600
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_IP_MAX=30
# Idle timeout (ms). Default 30 minutes.
SESSION_INACTIVITY_MS=1800000
# Bind session to client IP in production (set false to disable).
# SESSION_IP_BIND=true
